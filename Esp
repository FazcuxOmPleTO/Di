-- básico
if not game:IsLoaded() then game.Loaded:Wait() end

-- services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local lp = Players.LocalPlayer

-- pasta esp
local ESPEnabled = false -- Começa desligado

local ESPFolder = Instance.new("Folder", game.CoreGui)
ESPFolder.Name = "ESPFolder"

-- Função para limpar o ESP
local function clearESP()
	for _,v in pairs(ESPFolder:GetChildren()) do
		v:Destroy()
	end
end

-- FUNÇÃO GATILHO: Detecta o clique diretamente no ExpBar.ExpBar
local function setupIdentityTrigger()
	local playerGui = lp:WaitForChild("PlayerGui")
	
	-- Tenta encontrar a ExpBar dentro da PlayerGui do jogador
	local expBarMain = playerGui:WaitForChild("ExpBar", 10)
	if expBarMain then
		local identidadeClick = expBarMain:WaitForChild("ExpBar", 5)
		
		if identidadeClick then
			-- Detecta o clique/toque na identidade sem deletar nada
			identidadeClick.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					
					-- Alterna o estado do ESP
					ESPEnabled = not ESPEnabled
					
					-- Notificação no chat para você saber se ligou ou desligou
					game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
						Text = "[ESP System]: " .. (ESPEnabled and "ATIVADO" or "DESATIVADO");
						Color = ESPEnabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0);
						Font = Enum.Font.SourceSansBold;
					})

					if not ESPEnabled then
						clearESP()
					end
				end
			end)
		end
	end
end

-- Executa o gatilho
task.spawn(setupIdentityTrigger)

-- função cor do time
local function getTeamColor(player)
	if lp.Team ~= nil and player.Team ~= nil then
		if player.Team == lp.Team then
			return Color3.fromRGB(0, 170, 255) -- azul aliado
		else
			return Color3.fromRGB(255, 0, 0) -- vermelho inimigo
		end
	end
	return Color3.fromRGB(255,255,255)
end

-- criar esp
local function createESP(plr)
	if not plr.Character or not plr.Character:FindFirstChild("Head") then
		return
	end

	-- billboard
	local Billboard = Instance.new("BillboardGui")
	Billboard.Name = plr.Name
	Billboard.Adornee = plr.Character.Head
	Billboard.AlwaysOnTop = true
	Billboard.Size = UDim2.new(0, 100, 0, 20)
	Billboard.StudsOffset = Vector3.new(0, 2, 0)
	Billboard.Parent = ESPFolder

	-- nome
	local nameTag = Instance.new("TextLabel")
	nameTag.Parent = Billboard
	nameTag.Size = UDim2.new(1,0,1,0)
	nameTag.BackgroundTransparency = 1
	nameTag.Font = Enum.Font.SourceSansBold
	nameTag.TextSize = 14
	nameTag.TextStrokeTransparency = 0
	nameTag.Text = plr.Name

	-- outline / highlight
	local highlight = Instance.new("Highlight")
	highlight.Name = plr.Name .. "_Highlight"
	highlight.Parent = ESPFolder
	highlight.Adornee = plr.Character
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.FillTransparency = 1
	highlight.OutlineTransparency = 0

	-- atualizar cor
	local function updateColors()
		local color = getTeamColor(plr)
		nameTag.TextColor3 = color
		highlight.OutlineColor = color
	end

	updateColors()

	plr:GetPropertyChangedSignal("Team"):Connect(updateColors)
	lp:GetPropertyChangedSignal("Team"):Connect(updateColors)
end

-- loop render
RunService.RenderStepped:Connect(function()
	if not ESPEnabled then
		return
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= lp and player.Character and player.Character:FindFirstChild("Head") then
			if not ESPFolder:FindFirstChild(player.Name) then
				createESP(player)
			end
		end
	end

	-- remover inválidos
	for _, esp in ipairs(ESPFolder:GetChildren()) do
		if esp:IsA("BillboardGui") then
			local target = Players:FindFirstChild(esp.Name)

			if not target or not target.Character or not target.Character:FindFirstChild("Head") then
				local hl = ESPFolder:FindFirstChild(esp.Name .. "_Highlight")
				if hl then hl:Destroy() end
				esp:Destroy()
			end
		end
	end
end)
